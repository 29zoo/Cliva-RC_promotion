# ============================================================
# 클라이언트 환경 변수 (client/.env)
# ============================================================
# KOIHA-NTRH client/.env.production.example 참고
# 사용법: copy client\.env.example client\.env  후 【입력】 항목 작성
# 변경 후 dev 재시작 또는 npm run build
# ============================================================

# 【입력】병원 홍보 동영상 URL
# - YouTube embed: https://www.youtube.com/embed/영상ID
# - 로컬 MP4: client/public/promo.mp4 업로드 후 → /promo.mp4
# - 비워두면: 10초 대기 후 퀴즈 단계 (영상 없음)
VITE_PROMO_VIDEO_URL=

# 【입력】API 베이스 URL (끝 슬래시 없음)
# - Nginx로 동일 도메인 + /api 프록시 → 비워두기 (상대 경로 /api 사용)
# - API가 다른 호스트/포트일 때만: https://promotion.cliva.net 또는 http://서버IP:4001
VITE_API_BASE_URL=

# 【선택】내부망 LAN에서 dev HMR (http://PC-IP:5180 접속 시)
# VITE_DEV_HMR_HOST=
