# ============================================================
# 클라이언트 환경 변수 (client/.env)
# ============================================================
# 사용법: copy client\.env.example client\.env
# 변경 후 dev 재시작 또는 npm run build
# ============================================================

# 【입력】API 베이스 URL (끝 슬래시 없음)
# - Nginx 동일 도메인 + /api·/uploads 프록시 → 비움 (상대 경로)
# - API가 다른 호스트/포트일 때: https://promotion.cliva.net 또는 http://서버IP:4001
VITE_API_BASE_URL=

# 【선택】내부망 LAN dev HMR (http://PC-IP:5180 접속 시)
# VITE_DEV_HMR_HOST=

# 홍보 영상: 관리자 화면 → 🎬 홍보 영상 → MP4 업로드 (env 설정 불필요)
