# ============================================================
# 서버 환경 변수 (server/.env)
# ============================================================
# 사용법 (PowerShell, booth-roulette 폴더에서):
#   copy server\.env.example server\.env
# 그다음 【입력】 표시 항목을 채운 뒤 저장하세요.
# ============================================================

# 【선택】API 서버 포트 (기본 4000)
# - 개발: client(Vite)가 이 포트로 API 프록시
# - 운영: npm start 후 http://서버IP:PORT 로 접속
PORT="4000"

# 【선택】서버 바인딩 주소
# - 0.0.0.0 : 같은 네트워크·외부에서 접속 허용
# - 127.0.0.1 : 이 PC에서만 접속
HOST="0.0.0.0"

# 【선택】SQLite 데이터베이스 경로
# - 기본값 유지 권장 (server/prisma/dev.db 생성)
# - 행사 후 백업: server/prisma/dev.db 파일 복사
DATABASE_URL="file:./dev.db?busy_timeout=10000"

# 【선택】개발 시 API 대기 시간(ms) — npm run dev 전용
# WAIT_FOR_SERVER_MS="180000"
