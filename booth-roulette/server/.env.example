# ============================================================
# 서버 환경 변수 (server/.env)
# ============================================================
# KOIHA-NTRH cert-quiz-package/server/.env.example 와 동일 서버·관례 기준
# 사용법: copy server\.env.example server\.env  후 【입력】 항목 작성
# ============================================================

# ── Prisma / DB ─────────────────────────────────────────
# 【입력】PostgreSQL 연결 문자열 (cert-quiz와 동일 DB 서버, DB명은 분리 권장)
# - cert-quiz: cert_quiz DB / 본 앱: booth_roulette DB (별도 생성)
# - 서버에서 DB 생성: CREATE DATABASE booth_roulette;
#
# 로컬 Docker (cliva-his-pg 등, 호스트 5433):
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5433/booth_roulette?schema=public"
# 운영 서버 (5432):
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/booth_roulette?schema=public"

# ── 실행 모드 ───────────────────────────────────────────
# 【입력】운영 배포 시 production
NODE_ENV=development

# ── CORS (운영 production 에서 필수) ───────────────────
# 【입력】프론트 실제 Origin, 콤마 구분
# - cert-quiz 예: https://edu.cliva.net
# - 부스 예: https://promotion.cliva.net
# - 개발: 비우면 reflect. 운영(production)에서는 필수
CORS_ORIGIN=

# ── 리버스 프록시 (Nginx 뒤 운영 시) ─────────────────────
# 【입력】Nginx 뒤에서 true
TRUST_PROXY=false

# ── 서버 바인딩 ─────────────────────────────────────────
# 【입력】cert-quiz(4000)와 충돌 방지 → 4001 권장
HOST=0.0.0.0
PORT=4001

# 【선택】로그: trace | debug | info | warn | error
LOG_LEVEL=info

# 【선택】개발 시 API 대기(ms) — npm run dev 전용
# WAIT_FOR_SERVER_MS=180000
